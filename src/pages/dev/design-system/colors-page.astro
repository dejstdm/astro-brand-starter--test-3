---
import DevLayout from '../../../layouts/DevLayout.astro';
---

<DevLayout>
  <div class="container py-5">
    <div class="row">
      <div class="col-12">
        <h1 class="display-4 mb-3">Colors</h1>
        <p class="lead text-muted mb-5">Complete color system using CSS custom properties for consistent theming and easy customization.</p>
      </div>
    </div>

    <!-- Brand Colors -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Brand Colors</h2>
          </div>
          <div class="card-body">
            <div class="row g-4">
              <div class="col-md-6 col-lg-3">
                <div class="border rounded p-3">
                  <div class="color-swatch brand-primary mb-3"></div>
                  <h4 class="h6 mb-2">Primary</h4>
                  <p class="mb-1 fw-bold">#4caf4f</p>
                  <p class="text-muted small mb-1">Brand/Primary</p>
                  <p class="text-muted small"><code>--color-primary</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-3">
                <div class="border rounded p-3">
                  <div class="color-swatch brand-secondary mb-3"></div>
                  <h4 class="h6 mb-2">Secondary</h4>
                  <p class="mb-1 fw-bold">#263238</p>
                  <p class="text-muted small mb-1">Brand/Secondary</p>
                  <p class="text-muted small"><code>--color-secondary</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-3">
                <div class="border rounded p-3">
                  <div class="color-swatch brand-info mb-3"></div>
                  <h4 class="h6 mb-2">Info</h4>
                  <p class="mb-1 fw-bold">#2194f3</p>
                  <p class="text-muted small mb-1">Brand/Info</p>
                  <p class="text-muted small"><code>--color-info</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-3">
                <div class="border rounded p-3">
                  <div class="color-swatch brand-primary-blue mb-3"></div>
                  <h4 class="h6 mb-2">Primary Blue</h4>
                  <p class="mb-1 fw-bold">#0671e0</p>
                  <p class="text-muted small mb-1">Primary/M_Blue</p>
                  <p class="text-muted small"><code>--color-primary-blue</code></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Neutral Colors -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Neutral Colors</h2>
          </div>
          <div class="card-body">
            <div class="row g-4">
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch neutral-black mb-3"></div>
                  <h4 class="h6 mb-2">Black</h4>
                  <p class="mb-1 fw-bold">#263238</p>
                  <p class="text-muted small mb-1">Neutral/Black</p>
                  <p class="text-muted small"><code>--color-black</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch neutral-dark-grey mb-3"></div>
                  <h4 class="h6 mb-2">Dark Grey</h4>
                  <p class="mb-1 fw-bold">#4d4d4d</p>
                  <p class="text-muted small mb-1">Neutral/D_Grey</p>
                  <p class="text-muted small"><code>--color-dark-grey</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch neutral-grey mb-3"></div>
                  <h4 class="h6 mb-2">Grey</h4>
                  <p class="mb-1 fw-bold">#717171</p>
                  <p class="text-muted small mb-1">Neutral/Grey</p>
                  <p class="text-muted small"><code>--color-grey</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch neutral-light-grey mb-3"></div>
                  <h4 class="h6 mb-2">Light Grey</h4>
                  <p class="mb-1 fw-bold">#89939e</p>
                  <p class="text-muted small mb-1">Neutral/L_Grey</p>
                  <p class="text-muted small"><code>--color-light-grey</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch neutral-grey-blue mb-3"></div>
                  <h4 class="h6 mb-2">Grey Blue</h4>
                  <p class="mb-1 fw-bold">#abbed1</p>
                  <p class="text-muted small mb-1">Neutral/Grey_Blue</p>
                  <p class="text-muted small"><code>--color-grey-blue</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch neutral-silver mb-3"></div>
                  <h4 class="h6 mb-2">Silver</h4>
                  <p class="mb-1 fw-bold">#f5f7fa</p>
                  <p class="text-muted small mb-1">Neutral/Silver</p>
                  <p class="text-muted small"><code>--color-silver</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch neutral-white mb-3"></div>
                  <h4 class="h6 mb-2">White</h4>
                  <p class="mb-1 fw-bold">#ffffff</p>
                  <p class="text-muted small mb-1">Neutral/White</p>
                  <p class="text-muted small"><code>--color-white</code></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Color Shades -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Color Shades</h2>
          </div>
          <div class="card-body">
            <div class="row g-4">
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch shade-1 mb-3"></div>
                  <h4 class="h6 mb-2">Shade 1</h4>
                  <p class="mb-1 fw-bold">#43a046</p>
                  <p class="text-muted small mb-1">Shade/S1</p>
                  <p class="text-muted small"><code>--color-shade-1</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch shade-2 mb-3"></div>
                  <h4 class="h6 mb-2">Shade 2</h4>
                  <p class="mb-1 fw-bold">#388e3b</p>
                  <p class="text-muted small mb-1">Shade/S2</p>
                  <p class="text-muted small"><code>--color-shade-2</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch shade-3 mb-3"></div>
                  <h4 class="h6 mb-2">Shade 3</h4>
                  <p class="mb-1 fw-bold">#237d31</p>
                  <p class="text-muted small mb-1">Shade/S3</p>
                  <p class="text-muted small"><code>--color-shade-3</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch shade-4 mb-3"></div>
                  <h4 class="h6 mb-2">Shade 4</h4>
                  <p class="mb-1 fw-bold">#1b5e1f</p>
                  <p class="text-muted small mb-1">Shade/S4</p>
                  <p class="text-muted small"><code>--color-shade-4</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch shade-5 mb-3"></div>
                  <h4 class="h6 mb-2">Shade 5</h4>
                  <p class="mb-1 fw-bold">#103e13</p>
                  <p class="text-muted small mb-1">Shade/S5</p>
                  <p class="text-muted small"><code>--color-shade-5</code></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Color Tints -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Color Tints</h2>
          </div>
          <div class="card-body">
            <div class="row g-4">
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch tint-1 mb-3"></div>
                  <h4 class="h6 mb-2">Tint 1</h4>
                  <p class="mb-1 fw-bold">#66bb69</p>
                  <p class="text-muted small mb-1">Tint/T1</p>
                  <p class="text-muted small"><code>--color-tint-1</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch tint-2 mb-3"></div>
                  <h4 class="h6 mb-2">Tint 2</h4>
                  <p class="mb-1 fw-bold">#81c784</p>
                  <p class="text-muted small mb-1">Tint/T2</p>
                  <p class="text-muted small"><code>--color-tint-2</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch tint-3 mb-3"></div>
                  <h4 class="h6 mb-2">Tint 3</h4>
                  <p class="mb-1 fw-bold">#a5d6a7</p>
                  <p class="text-muted small mb-1">Tint/T3</p>
                  <p class="text-muted small"><code>--color-tint-3</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch tint-4 mb-3"></div>
                  <h4 class="h6 mb-2">Tint 4</h4>
                  <p class="mb-1 fw-bold">#c8e6c9</p>
                  <p class="text-muted small mb-1">Tint/T4</p>
                  <p class="text-muted small"><code>--color-tint-4</code></p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-4">
                <div class="border rounded p-3">
                  <div class="color-swatch tint-5 mb-3"></div>
                  <h4 class="h6 mb-2">Tint 5</h4>
                  <p class="mb-1 fw-bold">#e8f5e9</p>
                  <p class="text-muted small mb-1">Tint/T5</p>
                  <p class="text-muted small"><code>--color-tint-5</code></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Colors -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Action Colors</h2>
          </div>
          <div class="card-body">
            <div class="row g-4">
              <div class="col-md-4">
                <div class="border rounded p-3">
                  <div class="color-swatch action-warning mb-3"></div>
                  <h4 class="h6 mb-2">Warning</h4>
                  <p class="mb-1 fw-bold">#fbc02d</p>
                  <p class="text-muted small mb-1">Action/Warning</p>
                  <p class="text-muted small"><code>--color-warning</code></p>
                </div>
              </div>
              
              <div class="col-md-4">
                <div class="border rounded p-3">
                  <div class="color-swatch action-error mb-3"></div>
                  <h4 class="h6 mb-2">Error</h4>
                  <p class="mb-1 fw-bold">#e53835</p>
                  <p class="text-muted small mb-1">Action/Error</p>
                  <p class="text-muted small"><code>--color-error</code></p>
                </div>
              </div>
              
              <div class="col-md-4">
                <div class="border rounded p-3">
                  <div class="color-swatch action-success mb-3"></div>
                  <h4 class="h6 mb-2">Success</h4>
                  <p class="mb-1 fw-bold">#2e7d31</p>
                  <p class="text-muted small mb-1">Action/Success</p>
                  <p class="text-muted small"><code>--color-success</code></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Usage Examples -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Usage Examples</h2>
          </div>
          <div class="card-body">
            <div class="row g-4">
              <div class="col-md-6">
                <div class="border rounded p-3">
                  <h4 class="h6 mb-3">Text Colors</h4>
                  <p class="text-primary mb-2">Primary text color</p>
                  <p class="text-secondary mb-2">Secondary text color</p>
                  <p class="text-muted mb-2">Muted text color</p>
                  <p class="text-info mb-2">Info text color</p>
                  <p class="text-success mb-2">Success text color</p>
                  <p class="text-warning mb-2">Warning text color</p>
                  <p class="text-danger mb-2">Error text color</p>
                </div>
              </div>
              
              <div class="col-md-6">
                <div class="border rounded p-3">
                  <h4 class="h6 mb-3">CSS Custom Properties</h4>
                  <p class="mb-2">Use colors in your CSS:</p>
                  <pre class="bg-dark text-light p-3 rounded small"><code>background-color: var(--color-primary);
color: var(--color-text-primary);
border: 1px solid var(--color-border-light);</code></pre>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DevLayout>

<style>
  /* Only component-specific styles allowed - no layout CSS */
  .color-swatch {
    width: 100%;
    height: 80px;
    border-radius: 8px;
    border: 1px solid var(--color-border-light);
  }
  
  /* Color Swatch Definitions */
  .brand-primary { background-color: var(--color-primary); }
  .brand-secondary { background-color: var(--color-secondary); }
  .brand-info { background-color: var(--color-info); }
  .brand-primary-blue { background-color: var(--color-primary-blue); }
  
  .neutral-black { background-color: var(--color-black); }
  .neutral-dark-grey { background-color: var(--color-dark-grey); }
  .neutral-grey { background-color: var(--color-grey); }
  .neutral-light-grey { background-color: var(--color-light-grey); }
  .neutral-grey-blue { background-color: var(--color-grey-blue); }
  .neutral-silver { background-color: var(--color-silver); }
  .neutral-white { background-color: var(--color-white); border: 1px solid var(--color-border-medium); }
  
  .shade-1 { background-color: var(--color-shade-1); }
  .shade-2 { background-color: var(--color-shade-2); }
  .shade-3 { background-color: var(--color-shade-3); }
  .shade-4 { background-color: var(--color-shade-4); }
  .shade-5 { background-color: var(--color-shade-5); }
  
  .tint-1 { background-color: var(--color-tint-1); }
  .tint-2 { background-color: var(--color-tint-2); }
  .tint-3 { background-color: var(--color-tint-3); }
  .tint-4 { background-color: var(--color-tint-4); }
  .tint-5 { background-color: var(--color-tint-5); }
  
  .action-warning { background-color: var(--color-warning); }
  .action-error { background-color: var(--color-error); }
  .action-success { background-color: var(--color-success); }
</style>
