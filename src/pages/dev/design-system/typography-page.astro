---
import DevLayout from '../../../layouts/DevLayout.astro';
---

<DevLayout>
  <div class="container py-5">
    <div class="row">
      <div class="col-12">
        <h1 class="display-4 mb-3">Typography</h1>
        <p class="lead text-muted mb-5">Complete typography system based on Inter font family with consistent sizing and spacing.</p>
      </div>
    </div>

    <!-- Headlines -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Headlines</h2>
          </div>
          <div class="card-body">
            <div class="row g-4">
              <div class="col-md-6 col-lg-3">
                <div class="border rounded p-3">
                  <h1 class="h1 mb-2">Headline 1</h1>
                  <p class="text-secondary small tracking-tight">Semi Bold, 64/76</p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-3">
                <div class="border rounded p-3">
                  <h2 class="h2 mb-2">Headline 2</h2>
                  <p class="text-secondary small tracking-tight">Semi Bold, 36/44</p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-3">
                <div class="border rounded p-3">
                  <h3 class="h3 mb-2">Headline 3</h3>
                  <p class="text-secondary small tracking-tight">Bold, 28/36</p>
                </div>
              </div>
              
              <div class="col-md-6 col-lg-3">
                <div class="border rounded p-3">
                  <h4 class="h4 mb-2">Headline 4</h4>
                  <p class="text-secondary small tracking-tight">Semi Bold, 20/28</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Body Text -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Body Text</h2>
          </div>
          <div class="card-body">
            <div class="row g-4">
              <div class="col-md-6">
                <div class="border rounded p-3">
                  <h3 class="h4 text-muted mb-3">Regular</h3>
                  
                  <div class="border-start border-primary ps-3 mb-3">
                    <p class="body-1 mb-1">Body 1</p>
                    <p class="text-secondary small tracking-tight">Regular, 18/28</p>
                  </div>
                  
                  <div class="border-start border-primary ps-3 mb-3">
                    <p class="body-2 mb-1">Body 2</p>
                    <p class="text-secondary small tracking-tight">Regular, 16/24</p>
                  </div>
                  
                  <div class="border-start border-primary ps-3 mb-3">
                    <p class="body-3 mb-1">Body 3</p>
                    <p class="text-secondary small tracking-tight">Regular, 14/20</p>
                  </div>
                  
                  <div class="border-start border-primary ps-3 mb-3">
                    <p class="body-4 mb-1">Body 4</p>
                    <p class="text-secondary small tracking-tight">Regular, 12/16</p>
                  </div>
                </div>
              </div>
              
              <div class="col-md-6">
                <div class="border rounded p-3">
                  <h3 class="h4 text-muted mb-3">Medium</h3>
                  
                  <div class="border-start border-primary ps-3 mb-3">
                    <p class="body-1-medium mb-1">Body 1</p>
                    <p class="text-secondary small tracking-tight">Medium, 18/28</p>
                  </div>
                  
                  <div class="border-start border-primary ps-3 mb-3">
                    <p class="body-2-medium mb-1">Body 2</p>
                    <p class="text-secondary small tracking-tight">Medium, 16/24</p>
                  </div>
                  
                  <div class="border-start border-primary ps-3 mb-3">
                    <p class="body-3-medium mb-1">Body 3</p>
                    <p class="text-secondary small tracking-tight">Medium, 14/20</p>
                  </div>
                  
                  <div class="border-start border-primary ps-3 mb-3">
                    <p class="body-4-medium mb-1">Body 4</p>
                    <p class="text-secondary small tracking-tight">Medium, 12/16</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Usage Examples -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Usage Examples</h2>
          </div>
          <div class="card-body">
            <div class="border rounded p-4 bg-light">
              <h1 class="h1 mb-3">Welcome to Our Platform</h1>
              <p class="body-1 mb-3">This is the main headline that introduces your content. It uses the largest typography scale to create visual hierarchy and draw attention.</p>
              
              <h2 class="h2 mb-3">Key Features</h2>
              <p class="body-2 mb-3">Secondary headlines help organize content into logical sections. They're smaller than the main headline but still prominent enough to guide readers.</p>
              
              <h3 class="h3 mb-3">Detailed Information</h3>
              <p class="body-2 mb-3">Tertiary headlines provide further content organization. They're perfect for subsections and detailed explanations.</p>
              
              <h4 class="h4 mb-3">Small Details</h4>
              <p class="body-3 mb-3">The smallest headline size is ideal for minor sections, labels, or supporting information that doesn't need to compete with main content.</p>
              
              <p class="body-2 mb-3">Body text provides the main content of your pages. It should be easy to read and properly sized for comfortable reading on all devices.</p>
              
              <p class="body-3 mb-0">Smaller body text works well for captions, footnotes, or secondary information that supports the main content without overwhelming it.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DevLayout>
