---
import DevLayout from '../../../layouts/DevLayout.astro';
import Clients from '../../../components/prod/Clients.astro';
import Testimonial from '../../../components/prod/Testimonial.astro';
---

<style>
  .component-link {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    padding: 0.5rem;
    border-radius: 0.375rem;
    position: relative;
  }

  .component-link:hover {
    color: #045049;
    background-color: rgba(0, 247, 214, 0.233);
    transform: translateX(4px);
  }

  .component-link .icon {
    width: 16px;
    height: 16px;
    fill: currentColor;
    transition: transform 0.3s ease;
  }

  .component-link:hover .icon {
    transform: translate(2px, -2px);
  }

  .component-section {
    margin-bottom: 1rem;
    margin-top: 1.5rem;
  }

  .component-title {
    margin-bottom: 0;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .prod-badge {
    background: linear-gradient(135deg, #059669, #047857);
    color: white;
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-left: 1rem;
    box-shadow: 0 2px 4px rgba(5, 150, 105, 0.2);
  }
</style>

<DevLayout>
    <div class="container py-5">
        <div class="row">
            <div class="col-12">
                <h1 class="display-4 mb-4 text-center">
                    Production Components
                    <span class="prod-badge">Prod</span>
                </h1>
                <p class="lead text-center text-muted mb-5">
                    Production-ready components for brand websites. These components are optimized, tested, and ready for real-world implementation.
                </p>
                <div class="alert alert-info text-center">
                    <strong>Note:</strong> These are production components located in <code>/src/components/prod/</code>. 
                    For example components, visit <a href="/dev/components-all" class="alert-link">Component Showcase</a>.
                </div>
            </div>
        </div>
    </div>

    <!-- Clients Component -->
    <div class="container component-section">
        <div class="row">
            <div class="col-12">
                <h2 class="component-title">
                    <a href="/dev/components-pages/clients-page" class="component-link" target="_blank" rel="noopener noreferrer">
                        Clients
                        <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                            <path d="M384 64C366.3 64 352 78.3 352 96C352 113.7 366.3 128 384 128L466.7 128L265.3 329.4C252.8 341.9 252.8 362.2 265.3 374.7C277.8 387.2 298.1 387.2 310.6 374.7L512 173.3L512 256C512 273.7 526.3 288 544 288C561.7 288 576 273.7 576 256L576 96C576 78.3 561.7 64 544 64L384 64zM144 160C99.8 160 64 195.8 64 240L64 496C64 540.2 99.8 576 144 576L400 576C444.2 576 480 540.2 480 496L480 416C480 398.3 465.7 384 448 384C430.3 384 416 398.3 416 416L416 496C416 504.8 408.8 512 400 512L144 512C135.2 512 128 504.8 128 496L128 240C128 231.2 135.2 224 144 224L224 224C241.7 224 256 209.7 256 192C256 174.3 241.7 160 224 160L144 160z"/>
                        </svg>
                    </a>
                </h2>
                <p class="text-muted mb-3">
                    <small>A responsive client logos showcase section with grid layout and hover effects.</small>
                </p>
            </div>
        </div>
    </div>
    <Clients />

    <!-- Testimonial Component -->
    <div class="container component-section">
        <div class="row">
            <div class="col-12">
                <h2 class="component-title">
                    <a href="/dev/components-pages/testimonial-page" class="component-link" target="_blank" rel="noopener noreferrer">
                        Testimonial
                        <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                            <path d="M384 64C366.3 64 352 78.3 352 96C352 113.7 366.3 128 384 128L466.7 128L265.3 329.4C252.8 341.9 252.8 362.2 265.3 374.7C277.8 387.2 298.1 387.2 310.6 374.7L512 173.3L512 256C512 273.7 526.3 288 544 288C561.7 288 576 273.7 576 256L576 96C576 78.3 561.7 64 544 64L384 64zM144 160C99.8 160 64 195.8 64 240L64 496C64 540.2 99.8 576 144 576L400 576C444.2 576 480 540.2 480 496L480 416C480 398.3 465.7 384 448 384C430.3 384 416 398.3 416 416L416 496C416 504.8 408.8 512 400 512L144 512C135.2 512 128 504.8 128 496L128 240C128 231.2 135.2 224 144 224L224 224C241.7 224 256 209.7 256 192C256 174.3 241.7 160 224 160L144 160z"/>
                        </svg>
                    </a>
                </h2>
                <p class="text-muted mb-3">
                    <small>Customer testimonial section with author information and client logos.</small>
                </p>
            </div>
        </div>
    </div>
    <Testimonial />

    <!-- Footer Section -->
    <div class="container py-5">
        <div class="row">
            <div class="col-12 text-center">
                <hr class="my-4">
                <div class="d-flex justify-content-center gap-4 flex-wrap mb-4">
                    <a href="/dev/components-all" class="btn btn-outline-primary">
                        View Example Components
                    </a>
                    <a href="/dev/design-system/buttons-page" class="btn btn-outline-secondary">
                        Design System
                    </a>
                </div>
                <p class="text-muted mb-0">
                    <small>All production components follow our design system guidelines and are ready for implementation.</small>
                </p>
            </div>
        </div>
    </div>
</DevLayout>