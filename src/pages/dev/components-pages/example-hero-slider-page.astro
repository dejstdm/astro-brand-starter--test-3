---
import DevLayout from '../../../layouts/DevLayout.astro';
import ExampleHeroSlider from '../../components/examples/ExampleHeroSlider.astro';
---

<DevLayout title="Example Hero Slider">
  <div class="component-showcase">
    <div class="container py-5">
      <div class="row">
        <div class="col-12">
          <h1 class="display-4 mb-3">Example Hero Slider</h1>
          <p class="lead text-muted mb-5">
            A responsive hero slider with navigation based on the Nexcent design. Features smooth transitions, 
            autoplay functionality, and responsive navigation.
          </p>
        </div>
      </div>
      
      <div class="row mb-5">
        <div class="col-12">
          <div class="card">
            <div class="card-header">
              <h2 class="h3 mb-0">Component Features</h2>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-6">
                  <h4 class="h5 mb-3">Navigation</h4>
                  <ul class="list-unstyled">
                    <li class="mb-2">✅ Responsive navigation bar</li>
                    <li class="mb-2">✅ Mobile menu toggle</li>
                    <li class="mb-2">✅ Brand logo and text</li>
                    <li class="mb-2">✅ Navigation links</li>
                    <li class="mb-2">✅ Login and Sign up buttons</li>
                  </ul>
                </div>
                <div class="col-md-6">
                  <h4 class="h5 mb-3">Hero Slider</h4>
                  <ul class="list-unstyled">
                    <li class="mb-2">✅ Swiper.js powered slider</li>
                    <li class="mb-2">✅ Auto-play with pause on hover</li>
                    <li class="mb-2">✅ Custom pagination dots</li>
                    <li class="mb-2">✅ Smooth slide transitions</li>
                    <li class="mb-2">✅ Responsive design</li>
                    <li class="mb-2">✅ Keyboard navigation</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="row mb-5">
        <div class="col-12">
          <div class="card">
            <div class="card-header">
              <h2 class="h3 mb-0">Usage Guidelines</h2>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-6">
                  <h4 class="h5 mb-3">Design System Colors</h4>
                  <ul class="list-unstyled">
                    <li class="mb-2">🎨 Primary: <code>--color-primary</code> (#4CAF4F)</li>
                    <li class="mb-2">🎨 Background: <code>--color-silver</code> (#F5F7FA)</li>
                    <li class="mb-2">🎨 Text: <code>--color-text-primary</code></li>
                    <li class="mb-2">🎨 Secondary text: <code>--color-grey</code></li>
                  </ul>
                </div>
                <div class="col-md-6">
                  <h4 class="h5 mb-3">Responsive Behavior</h4>
                  <ul class="list-unstyled">
                    <li class="mb-2">📱 Mobile: Stacked layout, hidden nav menu</li>
                    <li class="mb-2">💻 Tablet: Reduced gaps, adjusted typography</li>
                    <li class="mb-2">🖥️ Desktop: Full layout with side-by-side content</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Component Display -->
  <ExampleHeroSlider />

  <div class="container py-5">
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h2 class="h3 mb-0">Technical Implementation</h2>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-6">
                <h4 class="h5 mb-3">Component Structure</h4>
                <pre class="bg-light p-3 rounded"><code>&lt;section class="page-sec page-sec--example-hero-slider"&gt;
  &lt;div class="example-hero-slider sec"&gt;
    &lt;nav class="example-hero-slider__nav"&gt;
      &lt;!-- Navigation content --&gt;
    &lt;/nav&gt;
    
    &lt;div class="example-hero-slider__content sec__content"&gt;
      &lt;div class="swiper example-hero-slider__swiper"&gt;
        &lt;!-- Slides --&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/section&gt;</code></pre>
              </div>
              <div class="col-md-6">
                <h4 class="h5 mb-3">JavaScript Initialization</h4>
                <pre class="bg-light p-3 rounded"><code>import { exampleHeroSlider } from './example-hero-slider.mjs';

// Initialize the slider
exampleHeroSlider();

// Control functions
controlHeroSlider('next');
controlHeroSlider('pause');</code></pre>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DevLayout>

<script type="module">
  import { exampleHeroSlider } from '/src/scripts/modules/example-hero-slider.mjs';
  exampleHeroSlider();
</script>
